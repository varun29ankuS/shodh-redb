# Generated by Cargo
# will have compiled files and executables
/target/

# Cargo.lock is committed -- workspace contains binary crates (redb-cli)
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# These are backup files generated by rustfmt
**/*.rs.bk

# IntelliJ
.idea/
**/*.iml


**/__pycache__
**/*.pyc

# Profiling
perf.data*
flamegraph.svg

# benchmark and test temporary files
/.tmp*
**/.tmp*
**/.storage_benchmark/
NUL

# proptest regression files (auto-generated)
**/proptest-regressions/

# nested build artifacts (workspace crates)
crates/*/target/

.vscode/settings.json

**/*.redb
.claude/

# Local audit docs (not for GitHub)
AUDIT_PLAYBOOK.md

# Benchmark datasets (SIFT1M and similar). Cargo.toml already excludes
# these from publication; this prevents accidental git commits too.
/data/
